@using Microsoft.AspNetCore.Components.Forms
@using System.Net.Http.Json
@using System.Text.Json
@using MudBlazor
@using GerenciadorEstoque.Client.Models
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">➕ Novo Produto</MudText>
    </TitleContent>

    <DialogContent>
        <MudTextField @bind-Value="_nome" Label="Nome" Required="true" Variant="Variant.Outlined" Class="mb-3" />
        <MudSelect @bind-Value="_tipo" Label="Tipo" Required="true" Variant="Variant.Outlined" Class="mb-3" T="string">
            <MudSelectItem Value="@("Blister unitário")">Blister unitário</MudSelectItem>
            <MudSelectItem Value="@("Triple pack")">Triple pack</MudSelectItem>
            <MudSelectItem Value="@("Quadri pack")">Quadri pack</MudSelectItem>
            <MudSelectItem Value="@("ETB")">ETB</MudSelectItem>
            <MudSelectItem Value="@("Booster Box")">Booster Box</MudSelectItem>
            <MudSelectItem Value="@("Box promocional")">Box promocional</MudSelectItem>
            <MudSelectItem Value="@("Starter Deck")">Starter Deck</MudSelectItem>
            <MudSelectItem Value="@("UPC")">UPC</MudSelectItem>
            <MudSelectItem Value="@("Case")">Case</MudSelectItem>
        </MudSelect>
        
        <MudNumericField @bind-Value="_precoTabelado" Label="Preço Tabelado (R$)" Variant="Variant.Outlined" Class="mb-3" T="decimal" Min="0" Format="N2" />
        <MudNumericField @bind-Value="_precoVenda" Label="Preço de Venda (R$)" Variant="Variant.Outlined" Class="mb-3" T="decimal" Min="0" Format="N2" />

        <div class="mb-2">
            <InputFile OnChange="OnInputFileChange" accept=".png,.jpg,.jpeg,.webp" />
            @if (!string.IsNullOrEmpty(_fileName))
            {
                <MudText Typo="Typo.caption" Class="mt-1">Arquivo: @_fileName</MudText>
            }
        </div>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancelar">Cancelar</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Salvar">Salvar</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    private string _nome = string.Empty;
    private string _tipo = string.Empty;
    private decimal _precoTabelado;
    private decimal _precoVenda;

    private IBrowserFile? _arquivo;
    private string? _fileName;

    private void OnInputFileChange(InputFileChangeEventArgs e)
    {
        _arquivo = e.File;
        _fileName = _arquivo?.Name;
    }

    private void Cancelar() => MudDialog.Cancel();

    private async Task Salvar()
    {
        if (string.IsNullOrWhiteSpace(_nome) || string.IsNullOrWhiteSpace(_tipo))
        {
            Snackbar.Add("Preencha nome e tipo.", Severity.Warning);
            return;
        }

        // DTO anónimo para evitar problemas de namespace/assembly na desserialização
        var produtoDto = new
        {
            Nome = _nome.Trim(),
            Tipo = _tipo,
            PrecoTabelado = _precoTabelado,
            PrecoVenda = _precoVenda
        };

        var resp = await Http.PostAsJsonAsync("api/produtos", produtoDto);
        if (!resp.IsSuccessStatusCode)
        {
            Snackbar.Add("Erro ao criar produto.", Severity.Error);
            return;
        }

        // tenta extrair id do JSON retornado de forma robusta
        int id = 0;
        try
        {
            var body = await resp.Content.ReadAsStringAsync();
            if (!string.IsNullOrWhiteSpace(body))
            {
                using var doc = JsonDocument.Parse(body);
                if (doc.RootElement.ValueKind == JsonValueKind.Object && doc.RootElement.TryGetProperty("id", out var idProp))
                {
                    if (idProp.ValueKind == JsonValueKind.Number && idProp.TryGetInt32(out var parsed))
                        id = parsed;
                }
            }
        }
        catch
        {
            // ignore parse errors, fallback para Location header
        }

        // fallback para Location header
        if (id == 0 && resp.Headers.Location is not null)
        {
            var segs = resp.Headers.Location.Segments;
            if (segs.Length > 0 && int.TryParse(segs.Last().Trim('/'), out var parsed))
                id = parsed;
        }

        if (_arquivo is not null && id > 0)
        {
            try
            {
                using var stream = _arquivo.OpenReadStream(5 * 1024 * 1024);
                var content = new MultipartFormDataContent();
                content.Add(new StreamContent(stream), "arquivo", _arquivo.Name);
                var up = await Http.PostAsync($"api/produtos/{id}/imagem", content);
                if (!up.IsSuccessStatusCode)
                    Snackbar.Add("Produto criado, mas falha ao enviar imagem.", Severity.Warning);
            }
            catch
            {
                Snackbar.Add("Erro no upload da imagem.", Severity.Warning);
            }
        }

        Snackbar.Add("Produto cadastrado!", Severity.Success);
        MudDialog.Close(DialogResult.Ok(true));
    }
}