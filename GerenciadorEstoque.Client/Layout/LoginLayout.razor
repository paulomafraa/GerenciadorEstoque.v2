@inherits LayoutComponentBase
@using MudBlazor

<MudThemeProvider Theme="_tema" IsDarkMode="false" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

@Body

@code {
    private MudTheme _tema = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#1976D2",
            Secondary = "#FF9800",
            Background = "#F5F5F5",
        },
        Typography = new Typography
        {
            Default = new DefaultTypography { FontFamily = new[] { "Inter", "sans-serif" } }
        }
    };
}
